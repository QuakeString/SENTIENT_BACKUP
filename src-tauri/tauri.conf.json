{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SENTIENT Backup & Restore",
  "version": "0.1.5",
  "identifier": "com.quakestring.sentient-backup",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SENTIENT Backup & Restore",
        "width": 1024,
        "height": 760,
        "minWidth": 820,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg", "deb", "appimage"],
    "resources": ["pgtools/bin/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
